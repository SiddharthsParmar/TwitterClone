                    <div class="comment_card_user">
                        <p style="color:white">${item.user_id}</p>
                    </div>

                </div>
                <div class="comment_content" style="background: black; margin-top:2px;color:white; padding: 10px 5px; border: .5px solid grey;">
                    <p>${item.comment_content}</p>
                   
                </div>
                
                <div class="comments-section "  style="  width: 100%;  background: #111; padding: 10px; margin-top: 10px; border-radius: 8px;">
         <p style="color: #888; font-size: 12px;">Comments for this tweet...</p> 
         <form action="/api/v1/users/submit_comment" enctype="application/x-www-form-urlencoded" method="POST">
            <input type="text" name="comment_content" placeholder="Write a Reply..." style="width: 80%; padding: 5px; background: #333; border: none; color: white; border-radius: 4px;">
            <input type="hidden" name="tweet_id" value=${item.tweet_id}>
            <input type="hidden" name="user_id" value=${item.user_id}>
