<!-- views/partials/_modals.ejs -->

<!-- Tweet Upload Modal -->
<div class="tweet_upload_container hide_uploader" id="tweet_upload_form_popup" style="z-index: 1001;">
    <div class="modal-content" style="height: auto; min-height: 400px; width: 90%; max-width: 500px; background: white; padding: 20px; border-radius: 10px; position: relative;">
        <button id="close_tweet_modal" style="position: absolute; top: 10px; right: 15px; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
        
        <form action="/api/v1/users/uploadtweet" method="post" enctype="multipart/form-data">
            <input type="hidden" name="user_id" value="<%= user.user_id %>">
            
            <textarea cols="50" rows="4" name="tweet_content" placeholder="What's happening?" style="width: 100%; border: none; font-size: 18px; resize: none; outline: none; font-family: inherit;"></textarea>
            
            <div class="image_preview_container" style="margin-top: 20px; height: 200px; width: 100%; background: #f5f5f5; display: none; justify-content: center; align-items: center; border-radius: 8px; overflow: hidden;">
                <img id="tweet_image_preview" style="max-width: 100%; max-height: 100%; object-fit: contain;"> 
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
                <label for="tweet_file_input" style="cursor: pointer; color: #1d9bf0; font-weight: bold;">📷 Add Media</label>
                <input type="file" id="tweet_file_input" name="tweet_image" accept="image/*,video/*" style="display: none;">
                
                <input type="submit" value="Post" style="padding: 8px 20px; background: #1d9bf0; border: none; color: white; border-radius: 20px; cursor: pointer; font-weight: bold;">
            </div>
        </form>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="tweet_upload_container hide_uploader" id="edit_profile_popup" style="z-index: 1002;">
    <div class="modal-content" style="height: auto; min-height: 500px; width: 90%; max-width: 500px; background: white; padding: 20px; border-radius: 10px; position: relative;">
        <button id="close_edit_modal" style="position: absolute; top: 10px; right: 15px; background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
        
        <h2 style="color: #000; margin-top: 0;">Edit Profile</h2>
        
        <form action="/api/v1/users/update_profile" method="post" enctype="multipart/form-data">
            <input type="hidden" name="user_id" value="<%= user.user_id %>">
            
            <!-- Cover Image Upload -->
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Cover Image</label>
                <input type="file" name="cover_image" accept="image/*" id="cover_input" style="width: 100%;">
                <div id="cover_preview_box" style="height: 100px; width: 100%; background: #eee; margin-top: 5px; display: none; overflow: hidden; border-radius: 5px;">
                    <img id="cover_preview" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
            </div>

            <!-- Profile Image Upload -->
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Profile Picture</label>
                <input type="file" name="profile_image" accept="image/*" id="profile_input" style="width: 100%;">
                <div id="profile_preview_box" style="height: 80px; width: 80px; border-radius: 50%; overflow: hidden; margin-top: 5px; border: 2px solid #ddd; display: none;">
                    <img id="profile_preview" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
            </div>

            <!-- Bio -->
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Bio</label>
                <textarea name="bio" rows="3" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;"><%= user.bio || '' %></textarea>
            </div>

            <input type="submit" value="Save Changes" style="width: 100%; padding: 10px; background: #1d9bf0; border: none; color: white; border-radius: 20px; cursor: pointer; font-weight: bold; margin-top: 10px;">
        </form>
    </div>
</div>