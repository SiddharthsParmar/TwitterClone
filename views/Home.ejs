    comment_container.appendChild(h1);

    const response = await fetch(`http://localhost:8080/api/v1/users/getTweetComments?tweet_id=${tweet_id}`,{
        method:'get'
    })
    const data = await response.json()
    console.log(data);
    
    

 data.data.forEach((item,index)=>{

    console.log(item.comment_id);

const comment_card = document.createElement("div");
comment_card.innerHTML = `
