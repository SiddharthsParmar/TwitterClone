CREATE TABLE likes_table(
like_id bigint primary key auto_increment,
user_id bigint,
tweet_original_id bigint,
FOREIGN KEY (tweet_original_id) REFERENCES tweets_table(tweet_original_id) ON DELETE CASCADE ON UPDATE CASCADE,
FOREIGN KEY (user_id) REFERENCES users_table(user_id) ON DELETE CASCADE ON UPDATE CASCADE
);
ALTER TABLE likes_table
ADD CONSTRAINT unique_like UNIQUE (user_id, tweet_original_id);
select * from likes_table;	
drop table likes_table;


CREATE TABLE IF NOT EXISTS follows_table(
relation_id bigint primary key auto_increment,
follower_id bigint,
followee_id bigint,
created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
FOREIGN KEY (follower_id) REFERENCES users_table(user_id) ON DELETE CASCADE ON UPDATE CASCADE,
FOREIGN KEY (followee_id) REFERENCES users_table(user_id) ON DELETE CASCADE ON UPDATE CASCADE,
CONSTRAINT UNIQUE(follower_id , followee_id)
);

SELECT * FROM follows_table;
drop table follows_table;


CREATE TABLE comments_table (
comment_id bigint primary key auto_increment,
user_id bigint not null,
tweet_id bigint not null,
comment_content text not null,
parent_id bigint default null,
FOREIGN KEY (user_id) references users_table(user_id) ON DELETE CASCADE ON UPDATE CASCADE,
FOREIGN KEY (tweet_id) references tweets_table(tweet_original_id) ON DELETE CASCADE ON UPDATE CASCADE
);
