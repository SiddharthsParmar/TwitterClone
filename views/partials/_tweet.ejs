
















<!-- views/partials/_tweet.ejs -->
<div class="single_tweet" style="border:1px solid #333; margin:10px; padding:10px; background:#000;">
    <!-- User Identity -->
    <div style="display:flex; gap:10px; margin-bottom: 10px;">
        <img src="<%= user.profile_image_path || 'https://via.placeholder.com/40' %>" 
             height="40" width="40" style="border-radius:50%; object-fit:cover;">
        <div style="display:flex; flex-direction:column;">
            <span style="color:white; font-weight:bold;"><%= user.firstname %> <span style="color:#888;">@<%= user.username %></span></span>
            <span class="tweet-time" data-time="<%= tweet.created_at %>" style="color:#888; font-size:12px;"></span>
        </div>
    </div>

    <!-- Media Content (Image or Video) -->
    <% if (tweet.tweet_media) { %>
        <div style="margin-top:10px; border-radius:10px; overflow:hidden; border:1px solid #333;">
            <!-- Check if it's a video or image based on extension or a flag if available -->
            <% if (tweet.tweet_media.endsWith('.mp4')) { %>
                <video width="100%" controls style="display:block;">
                    <source src="/uploads/<%= tweet.tweet_media %>" type="video/mp4">
                    Your browser does not support video.
                </video>
            <% } else { %>
                <img src="/uploads/<%= tweet.tweet_media %>" style="width:100%; display:block; object-fit:cover;" loading="lazy">
            <% } %>
        </div>
    <% } %>

    <!-- Text Content -->
    <p style="color:white; margin: 10px 0; line-height: 1.4;"><%= tweet.tweet_content %></p>

    <!-- Action Buttons -->
    <div class="tweet_controls" style="display: flex; justify-content: space-around; align-items: center; margin-top: 10px; border-top: 1px solid #222; padding-top: 10px;">
        
        <!-- Like -->
        <button class="icon-btn like-btn" 
                style="background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; color: #888;"
                data-tweet-id="<%= tweet.tweet_original_id %>" 
                data-user-id="<%= user.user_id %>"> 
            <span style="font-size: 20px;">❤️</span> 
            <span class="like-count" style="font-size: 12px; margin-top: 2px;">0</span> 
        </button>

        <!-- Comment -->
        <button class="icon-btn comment-btn" 
                style="background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; color: #888;"
                data-tweet-id="<%= tweet.tweet_original_id %>">
             <span style="font-size: 20px;">💬</span> 
             <span style="font-size: 12px; margin-top: 2px;">Comment</span> 
        </button>

        <!-- Retweet -->
        <button class="icon-btn retweet-btn" 
                style="background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; color: #888;"
                data-tweet-id="<%= tweet.tweet_original_id %>"
                data-user-id="<%= user.user_id %>"> 
            <span style="font-size: 20px;">🔄</span> 
            <span style="font-size: 12px; margin-top: 2px;">Retweet</span> 
        </button>

        <!-- Delete (Only show if viewing own profile) -->
       
    </div>

    <!-- Hidden Comments Section -->
    <div class="comments-section" style="display: none; width: 100%; background: #111; padding: 10px; margin-top: 10px; border-radius: 8px;">
        <p style="color: #888; font-size: 12px;">Comments for this tweet...</p> 
        <input type="text" placeholder="Write a comment..." class="comment-input" style="width: 80%; padding: 5px; background: #333; border: none; color: white; border-radius: 4px;">
        <button class="post-comment-btn" style="padding: 5px 10px; background: #1d9bf0; color: white; border: none; border-radius: 4px; cursor: pointer;">Post</button> 
    </div>
</div>