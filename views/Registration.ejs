<script>

const ValidationRules = {
    firstname: {
        minLength: 2,
        maxLength: 50,
        pattern: /^[a-zA-Z\s'-]+$/,
        messages: {
            required: 'First name is required',
            minLength: 'First name must be at least 2 characters',
            maxLength: 'First name cannot exceed 50 characters',
            pattern: 'First name can only contain letters, spaces, hyphens, and apostrophes'
        }
    },
    lastname: {
        minLength: 2,
        maxLength: 50,
        pattern: /^[a-zA-Z\s'-]+$/,
        messages: {
            required: 'Last name is required',
            minLength: 'Last name must be at least 2 characters',
            maxLength: 'Last name cannot exceed 50 characters',
            pattern: 'Last name can only contain letters, spaces, hyphens, and apostrophes'
        }
    },
    email: {
        pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/,
        messages: {
            required: 'Email address is required',
            pattern: 'Please enter a valid email address'
        }
    },
    phone_number: {
        pattern: /^[\d\s\-\+\(\)]+$/,
        minLength: 10,
        messages: {
            required: 'Phone number is required',
            pattern: 'Phone number can only contain digits, spaces, hyphens, and parentheses',
            minLength: 'Phone number must be at least 10 digits'
        }
    },
    username: {
        minLength: 3,
        maxLength: 100,
        pattern: /^[a-zA-Z0-9_]+$/,
        messages: {
            required: 'Username is required',
            minLength: 'Username must be at least 3 characters',
            maxLength: 'Username cannot exceed 100 characters',
            pattern: 'Username can only contain letters, numbers, and underscores',
            taken: 'This username is already taken'
        }
    },
    birth_date: {
        messages: {
            required: 'Birth date is required',
            invalid: 'You must be at least 13 years old'
        }
    },
    account_based_in: {
        messages: {
            required: 'Please select a country or region'
        }
    },
    password: {
        minLength: 8,
        pattern: /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]+$/,
        messages: {
            required: 'Password is required',
            minLength: 'Password must be at least 8 characters',
            pattern: 'Password must contain uppercase, lowercase, number, and special character'
        }
    },
    confirm_password: {
        messages: {
            required: 'Please confirm your password',
            mismatch: 'Passwords do not match'
        }
    }
};

class FormValidator {
    constructor(formId) {
        this.form = document.getElementById(formId);
        this.errors = {};
    }

    validateField(fieldName, value) {
        const rules = ValidationRules[fieldName];
        if (!rules) return null;

        // Check if required
        if (!value.trim()) {
            return rules.messages.required;
        }

        // Check minLength
        if (rules.minLength && value.length < rules.minLength) {
            return rules.messages.minLength;
        }

        // Check maxLength
        if (rules.maxLength && value.length > rules.maxLength) {
            return rules.messages.maxLength;
        }

        // Check pattern
        if (rules.pattern && !rules.pattern.test(value)) {
            return rules.messages.pattern;
        }

        // Special validations
        if (fieldName === 'birth_date') {
            return this.validateBirthDate(value);
        }

        return null;
    }

    validateBirthDate(dateStr) {
        const birthDate = new Date(dateStr);
        const today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        const monthDiff = today.getMonth() - birthDate.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
            age--;
        }

        if (age < 13) {
            return ValidationRules.birth_date.messages.invalid;
        }

        return null;
    }

    validatePasswordMatch(password, confirmPassword) {
        if (password !== confirmPassword) {
            return ValidationRules.confirm_password.messages.mismatch;
        }
        return null;
    }

    displayError(fieldName, message) {
        const errorElement = document.getElementById(`${fieldName}_error`);
        const inputElement = document.getElementById(fieldName);

        if (message) {
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.add('show');
            }
            if (inputElement) {
                inputElement.classList.add('error');
                inputElement.classList.remove('success');
            }
            this.errors[fieldName] = message;
        } else {
            if (errorElement) {
                errorElement.textContent = '';
                errorElement.classList.remove('show');
            }
            if (inputElement) {
                inputElement.classList.remove('error');
                inputElement.classList.add('success');
            }
            delete this.errors[fieldName];
        }
    }

    isValid() {
        return Object.keys(this.errors).length === 0;
    }
}

// Password strength indicator
class PasswordStrength {
    static calculate(password) {
        let strength = 0;

        if (password.length >= 8) strength++;
        if (password.length >= 12) strength++;
        if (/[a-z]/.test(password)) strength++;
        if (/[A-Z]/.test(password)) strength++;
        if (/\d/.test(password)) strength++;
        if (/[@$!%*?&]/.test(password)) strength++;

        return strength;
    }

    static getLevel(strength) {
        if (strength <= 2) return 'weak';
        if (strength <= 3) return 'fair';
        if (strength <= 4) return 'good';
        return 'strong';
    }

    static updateUI(password) {
        const strengthBar = document.getElementById('password_strength');
        const bar = strengthBar.querySelector('.strength_bar');

        if (!password) {
            strengthBar.classList.remove('active');
            return;
        }

        const strength = this.calculate(password);
        const level = this.getLevel(strength);

        strengthBar.classList.add('active');
        bar.className = `strength_bar ${level}`;
    }
}



class RegistrationFormHandler {
    constructor(formId, apiEndpoint) {
        this.form = document.getElementById(formId);
        this.apiEndpoint = apiEndpoint;
        this.validator = new FormValidator(formId);
        this.usernameCheckTimeout = null;
        this.init();
    }

    init() {
        this.setupEventListeners();
    }

    setupEventListeners() {
        // Real-time validation
        const fields = ['firstname', 'lastname', 'email', 'phone_number', 'username', 'birth_date', 'account_based_in', 'password', 'confirm_password'];

        fields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (field) {
                field.addEventListener('blur', () => this.validateAndDisplay(fieldName));
                field.addEventListener('input', () => this.handleFieldInput(fieldName));
            }
        });

        // Password visibility toggle
        document.getElementById('password_toggle')?.addEventListener('click', (e) => {
            e.preventDefault();
            this.togglePasswordVisibility('password', 'password_toggle');
        });

        document.getElementById('confirm_password_toggle')?.addEventListener('click', (e) => {
            e.preventDefault();
            this.togglePasswordVisibility('confirm_password', 'confirm_password_toggle');
        });

        // Password strength indicator
        document.getElementById('password')?.addEventListener('input', (e) => {
            PasswordStrength.updateUI(e.target.value);
        });

        // Form submission
        this.form?.addEventListener('submit', (e) => this.handleSubmit(e));
    }

    handleFieldInput(fieldName) {
        if (fieldName === 'username') {
            // Debounce username availability check
            clearTimeout(this.usernameCheckTimeout);
            this.usernameCheckTimeout = setTimeout(() => {
                this.checkUsernameAvailability(document.getElementById('username').value);
            }, 500);
        }

        if (fieldName === 'confirm_password') {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirm_password').value;
            if (confirmPassword) {
                const error = this.validator.validatePasswordMatch(password, confirmPassword);
                this.validator.displayError('confirm_password', error);
            }
        }
    }

    validateAndDisplay(fieldName) {
        const field = document.getElementById(fieldName);
        if (!field) return;

        const error = this.validator.validateField(fieldName, field.value);
        this.validator.displayError(fieldName, error);
    }

    togglePasswordVisibility(fieldId, toggleId) {
        const field = document.getElementById(fieldId);
        const toggle = document.getElementById(toggleId);
        const icon = toggle.querySelector('.toggle_icon');

        if (field.type === 'password') {
            field.type = 'text';
            icon.textContent = '🙈';
        } else {
            field.type = 'password';
            icon.textContent = '👁️';
        }
    }

    async checkUsernameAvailability(username) {
        if (username.length < 3) {
            this.validator.displayError('username', null);
            return;
        }

        const status = document.getElementById('username_status');
        status.classList.add('checking');
        status.textContent = '⏳';

        try {
            const response = await this.fetchAPI(`${this.apiEndpoint}/check-username`, {
                method: 'POST',
                body: JSON.stringify({ username })
            });

            if (response.available) {
                status.classList.remove('checking');
                status.classList.add('available');
                status.textContent = '✓';
                this.validator.displayError('username', null);
            } else {
                status.classList.remove('checking');
                status.classList.add('taken');
                status.textContent = '✗';
                this.validator.displayError('username', ValidationRules.username.messages.taken);
            }
        } catch (error) {
            console.error('Username check failed:', error);
            status.classList.remove('checking');
        }
    }

    async validateForm() {
        const fields = ['firstname', 'lastname', 'email', 'phone_number', 'username', 'birth_date', 'account_based_in', 'password', 'confirm_password'];

        fields.forEach(fieldName => {
            this.validateAndDisplay(fieldName);
        });

        // Additional password match validation
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        const passwordMatchError = this.validator.validatePasswordMatch(password, confirmPassword);
        if (passwordMatchError) {
            this.validator.displayError('confirm_password', passwordMatchError);
        }

        return this.validator.isValid();
    }

    async handleSubmit(e) {
        e.preventDefault();

        // Validate form
        const isValid = await this.validateForm();
        if (!isValid) {
            console.log('Form validation failed');
            return;
        }

        // Show loading state
        this.setSubmitLoading(true);

        try {
            // Collect form data
            const formData = this.collectFormData();

            // Submit to API
            const response = await this.submitRegistration(formData);

            if (response.success) {
                // Handle success
                this.handleSuccess(response);
            } else {
                this.handleError(response.message || 'Registration failed');
            }
        } catch (error) {
            this.handleError(error.message || 'An error occurred during registration');
        } finally {
            this.setSubmitLoading(false);
        }
    }

    collectFormData() {
        return {
            firstname: document.getElementById('firstname').value.trim(),
            lastname: document.getElementById('lastname').value.trim(),
            email: document.getElementById('email').value.trim(),
            phone_number: document.getElementById('phone_number').value.trim(),
            username: document.getElementById('username').value.trim(),
            birth_date: document.getElementById('birth_date').value,
            account_based_in: document.getElementById('account_based_in').value,
            password_hash: document.getElementById('password').value,
            joined_date : "2026-04-02",
            connected_via: document.getElementById('connected_via').value
        };
    }

    async submitRegistration(data) {
        return await this.fetchAPI(`http://localhost:8080/api/v1/users/register`, {
            method: 'POST',
            
            body: JSON.stringify(data)
        });
    }

    async fetchAPI(url, options = {}) {
        const defaultOptions = {
            headers: {
                'Content-Type': 'application/json',
            }
        };

        const response = await fetch(url, { ...defaultOptions, ...options });

        if (!response.ok) {
            const error = await response.json();
            throw new Error(error.message || `HTTP ${response.status}`);
        }

        return await response.json();
    }

    setSubmitLoading(isLoading) {
        const submitBtn = document.getElementById('submitBtn');
        const loader = document.getElementById('loader');

        if (isLoading) {
            submitBtn.disabled = true;
            loader.classList.add('active');
        } else {
            submitBtn.disabled = false;
            loader.classList.remove('active');
        }
    }

    handleSuccess(response) {
        console.log('Registration successful:', response);
        
        // Show success message (you can add a toast notification here)
        alert('Account created successfully!');

        // Redirect to login or dashboard
        window.location.href = response.redirectUrl || '/login';
    }

    handleError(message) {
        console.error('Registration error:', message);
        
        // Show error message
        alert(`Error: ${message}`);

        // You can also display field-specific errors
        // this.validator.displayError('email', message);
    }
}

// Initialize form handler when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
    const formHandler = new RegistrationFormHandler(
        'registrationForm',
        'http://localhost:8080/api/v1/users/' // Replace with your API endpoint
    );
});

